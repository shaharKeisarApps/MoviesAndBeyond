{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "gradle": {
    "enabled": true,
    "fileMatch": [
      "(^|/)gradle/libs\\.versions\\.toml$"
    ]
  },
  "labels": [
    "dependencies",
    "renovate"
  ],
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "Dependency Updates",
  "automerge": false,
  "ignoreDeps": [
    "moviesandbeyond.android.application",
    "moviesandbeyond.android.application.compose",
    "moviesandbeyond.android.library",
    "moviesandbeyond.android.library.compose",
    "moviesandbeyond.android.hilt",
    "moviesandbeyond.android.feature",
    "moviesandbeyond.android.screenshot.test"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "gradle"
      ],
      "matchFileNames": [
        "gradle/libs.versions.toml"
      ],
      "groupName": "Gradle Version Catalog Updates",
      "groupSlug": "gradle-version-catalog",
      "description": "Group all Gradle Version Catalog updates into a single PR"
    }
  ]
}
